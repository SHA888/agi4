#!/bin/bash
# Pre-commit hook for agi4
# Checks code formatting and linting before allowing commits

set -e

echo "🔍 Running pre-commit checks..."

# Check if we're in the runner directory (Rust code)
if [ -f "runner/Cargo.toml" ]; then
    cd runner

    echo "📋 Checking Rust formatting..."
    if ! cargo fmt -- --check; then
        echo "❌ Code formatting issues found. Run: cargo fmt"
        exit 1
    fi

    echo "🔧 Running clippy linter..."
    if ! cargo clippy --all-targets --all-features -- -D warnings 2>&1; then
        echo "❌ Clippy warnings found. Fix them or run: cargo clippy --fix"
        exit 1
    fi

    cd ..
fi

echo "✅ Pre-commit checks passed!"
exit 0
